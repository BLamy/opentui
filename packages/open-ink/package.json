{
  "name": "open-ink",
  "version": "0.1.90",
  "description": "Ink-compatible React renderer powered by OpenTUI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/opentui",
    "directory": "packages/open-ink"
  },
  "module": "src/index.ts",
  "main": "src/index.ts",
