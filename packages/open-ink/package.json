  },
  "peerDependenciesMeta": {
    "react-devtools-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentui/react-runtime": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.32.0",
    "@types/ws": "^8.18.1",
    "react": ">=19.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5",
    "ws": "^8.18.0"
