---
import Base from "../../layouts/Base.astro"
import { withBase } from "../../utils/base-path"

const wasmUrl = withBase("/opentui/opentui.wasm")
---

<Base title="OpenTUI Example Preview" description="Live preview for OpenTUI documentation examples.">
  <main class="doc-preview-page">
    <section class="doc-preview-page__surface" data-preview-root data-wasm-url={wasmUrl}>
      <div class="doc-preview-page__terminal" data-preview-terminal></div>
    </section>
  </main>

  <script>
    import "../../scripts/example-preview.ts"
  </script>
</Base>

<style>
  :global(html),
  :global(body) {
    height: 100%;
    overflow: hidden;
    background: var(--doc-example-code-bg);
  }

  .doc-preview-page {
    height: 100%;
    min-height: 100%;
    background: var(--doc-example-code-bg);
  }

  .doc-preview-page__surface {
    display: flex;
    position: relative;
    height: 100%;
    min-height: 100%;
    background: var(--doc-example-code-bg);
    overflow: hidden;
  }

  .doc-preview-page__surface :global([data-preview-status]) {
    display: none !important;
  }

  .doc-preview-page__terminal {
    position: relative;
    flex: 1;
    width: 100%;
    min-height: 0;
    box-sizing: border-box;
    padding: 10px;
    background: var(--doc-example-code-bg);
    overflow: hidden;
  }

  .doc-preview-page__terminal :global(canvas) {
    display: block;
    border-radius: 0px;
  }

  .doc-preview-page__terminal:focus-visible {
    outline: none;
  }
</style>
