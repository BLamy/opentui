---
import Base from "../../layouts/Base.astro"
---

<Base title="OpenTUI Browser Demo" description="Embedded OpenTUI browser demo powered by the browser runtime.">
  <main class="browser-demo-page">
    <section class="browser-demo-page__shell">
      <div class="browser-demo-page__chrome">
        <div class="browser-demo-page__lights">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="browser-demo-page__meta">
          <span>zig wasm</span>
          <span>xterm.js</span>
          <span>@opentui/core/browser</span>
        </div>
      </div>

      <div class="browser-demo-page__surface" data-workbench-root data-wasm-url="/opentui/opentui.wasm">
        <div class="browser-demo-page__status" data-workbench-status data-state="loading">
          Loading browser runtime...
        </div>
        <div class="browser-demo-page__terminal" data-workbench-terminal></div>
      </div>
    </section>
  </main>

  <script>
    import "../../scripts/workbench.ts"
  </script>
</Base>

<style>
  .browser-demo-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(245, 171, 83, 0.2), transparent 26%),
      radial-gradient(circle at top right, rgba(77, 198, 194, 0.18), transparent 22%),
      linear-gradient(180deg, #efe4d2 0%, #e7d9c2 100%);
  }

  .browser-demo-page__shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background:
      linear-gradient(180deg, rgba(17, 25, 33, 0.96), rgba(9, 15, 20, 0.98)),
      linear-gradient(90deg, rgba(77, 198, 194, 0.06), transparent 30%, rgba(245, 171, 83, 0.08));
    border: 1px solid rgba(16, 31, 40, 0.28);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 18px 42px rgba(29, 24, 18, 0.18);
    overflow: hidden;
  }

  .browser-demo-page__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.035);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .browser-demo-page__lights {
    display: flex;
    gap: 8px;
  }

  .browser-demo-page__lights span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    display: block;
  }

  .browser-demo-page__lights span:nth-child(1) {
    background: #ff8c69;
  }

  .browser-demo-page__lights span:nth-child(2) {
    background: #f4c94c;
  }

  .browser-demo-page__lights span:nth-child(3) {
    background: #53c98d;
  }

  .browser-demo-page__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .browser-demo-page__meta span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(233, 244, 248, 0.72);
    border: 1px solid rgba(233, 244, 248, 0.12);
    border-radius: 999px;
    padding: 7px 10px;
  }

  .browser-demo-page__surface {
    position: relative;
    flex: 1;
    min-height: 0;
    padding: 14px;
    background:
      linear-gradient(180deg, rgba(8, 12, 16, 0.28), transparent 28%),
      linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px),
      linear-gradient(180deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
    background-size:
      auto,
      22px 22px,
      22px 22px;
  }

  .browser-demo-page__status {
    position: absolute;
    top: 18px;
    left: 18px;
    z-index: 2;
    max-width: min(520px, calc(100% - 36px));
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.5;
    letter-spacing: 0.04em;
    color: rgba(242, 247, 249, 0.86);
    padding: 11px 14px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(7, 10, 14, 0.78);
    backdrop-filter: blur(14px);
  }

  .browser-demo-page__status[data-state="ready"] {
    color: rgba(161, 237, 197, 0.96);
    border-color: rgba(97, 196, 140, 0.34);
  }

  .browser-demo-page__status[data-state="error"] {
    color: rgba(255, 190, 168, 0.96);
    border-color: rgba(255, 128, 99, 0.34);
  }

  .browser-demo-page__terminal {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(6, 10, 13, 0.92);
    overflow: hidden;
  }

  .browser-demo-page__terminal :global(.xterm) {
    height: 100%;
    padding: 12px;
  }

  .browser-demo-page__terminal :global(.xterm-viewport),
  .browser-demo-page__terminal :global(.xterm-screen) {
    border-radius: 12px;
  }

  @media (max-width: 720px) {
    .browser-demo-page__chrome {
      padding: 14px;
    }

    .browser-demo-page__meta {
      gap: 8px;
    }

    .browser-demo-page__surface {
      padding: 12px;
    }
  }
</style>
